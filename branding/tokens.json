  "headline": "Build with AI. Own it.",

  "colors": {
    "neutrals": {
      "paper-0": "#FAFAF8",
      "paper-1": "#F5F5F2",
      "paper-2": "#EEECEA",
      "white":   "#FFFFFF",
      "line":        "#E2E0DC",
      "line-strong": "#D0CEC8"
    },
    "green": {
      "ink":       "#1E2B1A",
      "pine":      "#2C4F38",
      "fern":      "#4A7C59",
      "moss":      "#4A6741",
      "sage":      "#7FAF8A",
      "sage-tint": "#E8EFE6",
      "deep-1":    "#0C2E2A",
      "deep-2":    "#144E46"
    },
    "terracotta": {
      "base": "#C1693A",
      "deep": "#A84E28"
    },
    "status": {
      "green": "#1D9E75",
      "red":   "#DC2626",
      "amber": "#D97706"
    }
  },

  "semantic": {
    "bg-primary":       "#FAFAF8",
    "bg-secondary":     "#F5F5F2",
    "bg-tertiary":      "#EEECEA",
    "bg-code":          "#F5F5F2",
    "bg-accent":        "#E8EFE6",
    "text-primary":     "#1E2B1A",
    "text-secondary":   "#4A5244",
    "text-tertiary":    "#8A9082",
    "text-accent":      "#4A6741",
    "border-primary":   "#E2E0DC",
    "border-secondary": "#EEECEA",
    "border-strong":    "#D0CEC8",
    "btn-primary-bg":   "#C1693A",
    "btn-primary-text": "#FFFFFF",
    "btn-ghost-text":   "#4A5244",
    "btn-ghost-border": "#D0CEC8"
  },

  "gradients": {
    "hero-ombre":   "linear-gradient(135deg, #E2F2EE 0%, #EFF7F5 50%, #FDF5F0 100%)",
    "grad-heading": "linear-gradient(90deg, #1F2E24, #3D6B4F)",
    "grad-green":   "linear-gradient(90deg, #3D6B4F, #4A7C59, #7FAF8A)",
    "grad-dark":    "linear-gradient(90deg, #0C2E2A, #144E46)",
    "grad-cta":     "linear-gradient(135deg, #A84E28, #C1693A)",
    "grad-band":    "linear-gradient(180deg, #F0F6F1, #FFFFFF)",
    "grad-callout": "linear-gradient(135deg, #E2F2EE, #FDF5F0)",
    "grad-footer":  "linear-gradient(135deg, #0C2E2A, #144E46)",
    "grad-logo":    "linear-gradient(90deg, #1F2E24, #4A7C59)"
  },

  "typography": {
    "fonts": {
      "display": "'Playfair Display', Georgia, 'Times New Roman', serif",
      "body":    "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "mono":    "'Geist Mono', 'SF Mono', 'Fira Code', 'Fira Mono', monospace"
    },
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700;800&family=Geist+Mono:wght@300;400;500&display=swap",
    "scale": {
      "xs":  "12px",
      "sm":  "13px",
      "base": "15px",
      "lg":  "18px",
      "xl":  "22px",
      "2xl": "28px",
      "3xl": "36px",
      "4xl": "48px"
    },
    "weights": {
      "light":    300,
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "lineHeights": {
      "tight":   1.08,
      "snug":    1.3,
      "normal":  1.55,
      "relaxed": 1.7
    },
    "letterSpacing": {
      "tighter": "-1.5px",
      "tight":   "-0.5px",
      "normal":  "-0.2px",
      "wide":    "1.5px"
    }
  },

  "radii": {
    "sm":   "6px",
    "md":   "8px",
    "lg":   "12px",
    "xl":   "16px",
    "pill": "100px"
  },

  "contrast": {
    "_note": "All body text/bg pairings pass WCAG AA (4.5:1 minimum). Primary text passes AAA (7:1).",
    "primary-on-paper":   { "ratio": "14.5:1", "pair": "#1E2B1A on #FAFAF8" },
    "secondary-on-paper": { "ratio": "7.4:1",  "pair": "#4A5244 on #FAFAF8" },
    "tertiary-on-paper":  { "ratio": "3.4:1",  "pair": "#8A9082 on #FAFAF8", "note": "Large text only (18px+) or UI components" },
    "accent-on-paper":    { "ratio": "6.6:1",  "pair": "#4A6741 on #FAFAF8" },
    "white-on-terracotta": { "ratio": "3.6:1", "pair": "#FFFFFF on #C1693A", "note": "Buttons: large/bold text" }
  },

  "logos": {
    "lockup": "TotallyWild.ai — robot mark + gradient wordmark. Rendered inline as SVG + text (src/components/LogoLockup.tsx); no separate day/night variants.",
    "files": {
      "favicon": "logos/svg/favicon.svg"
    },
    "clearSpace": "Minimum clear space around the mark is equal to the width of the mark circle.",
    "minimumSize": "Mark: 24px. Full lockup: 120px width."
  }
}
